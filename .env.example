# .env.example — Copy to .env and fill in your values

# ─── Database ──────────────────────────────────────────────────────────────────
# Local development: use this directly
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/platelink

# Render production: Render injects DATABASE_URL as postgres://...
# Set RENDER_DATABASE_URL to that value — the app auto-converts the prefix.
RENDER_DATABASE_URL=postgres://user:pass@host:5432/dbname

POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=platelink

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ──────────────────────────────────────────────────────────────────────
# "*" = allow all (dev). In production, set to your frontend URL(s):
# ALLOWED_ORIGINS=https://app.platelink.africa,https://platelink.africa
ALLOWED_ORIGINS=*

# ─── Port (Render injects this automatically — do not set manually on Render) ──
PORT=8000

# ─── M-Pesa ────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_key
MPESA_CONSUMER_SECRET=your_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mpesa/callback

# ─── SMS (Africa's Talking) ────────────────────────────────────────────────────
SMS_API_KEY=your_key
SMS_SENDER_ID=PLATELINK

# ─── Email (Brevo) ─────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@platelink.africa
BREVO_SENDER_NAME=PlateLink Africa

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://key:secret@cloudname

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── Pesapal ───────────────────────────────────────────────────────────────────
PESAPAL_CONSUMER_KEY=your_key
PESAPAL_CONSUMER_SECRET=your_secret
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CALLBACK_URL=https://yourdomain.com/api/v1/payments/pesapal/callback

